{
  "mcpServers": {
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "sanity": {
      "url": "https://mcp.sanity.io/v1",
      "type": "http",
      "headers": {
        "Authorization": "Bearer ${SANITY_API_WRITE_TOKEN}",
        "Sanity-Project-Id": "${SANITY_PROJECT_ID}",
        "Sanity-Dataset": "${SANITY_DATASET}"
      }
    }
  }
}