# ===========================================
# STUDIO APP ENVIRONMENT VARIABLES
# ===========================================
# This file is OPTIONAL - Studio automatically uses root .env variables
# (SANITY_PROJECT_ID, SANITY_DATASET, SANITY_STUDIO_HOST)
#
# Only create this file if you need to:
# - Override root values for local development
# - Add studio-specific environment variables

# Example overrides (optional):
# SANITY_STUDIO_PROJECT_ID=different-project-id
# SANITY_STUDIO_DATASET=development
# SANITY_STUDIO_HOST=localhost
# SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
# SANITY_STUDIO_PREVIEW_SECRET=your-preview-secret-here
# SANITY_STUDIO_UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# External publishing ("Publish Externally" document action on articles):
# Medium is handled via copy-paste (its publishing API was retired), so only
# the Dev.to key is needed:
# SANITY_STUDIO_DEVTO_KEY=your-devto-api-key
